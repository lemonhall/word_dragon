{"global_seq": 11201, "batch_seq": 1, "idiom_id": "idiom-11201", "text": "不堪视听", "pinyin": "bù kān shì tīng", "short_explanation": "堪：可，能。"}
{"global_seq": 11202, "batch_seq": 2, "idiom_id": "idiom-11202", "text": "不堪言状", "pinyin": "bù kān yán zhuàng", "short_explanation": "指无法用语言来形容。"}
{"global_seq": 11203, "batch_seq": 3, "idiom_id": "idiom-11203", "text": "不声不吭", "pinyin": "bù shēng bù kēng", "short_explanation": "指不说话。"}
{"global_seq": 11204, "batch_seq": 4, "idiom_id": "idiom-11204", "text": "不壹而三", "pinyin": "bù yī ér sān", "short_explanation": "指再三。"}
{"global_seq": 11205, "batch_seq": 5, "idiom_id": "idiom-11205", "text": "不失旧物", "pinyin": "bù shī jiù wù", "short_explanation": "旧物：指原有的事业或原有的山河。"}
{"global_seq": 11206, "batch_seq": 6, "idiom_id": "idiom-11206", "text": "不奈之何", "pinyin": "bù nai zhī hé", "short_explanation": "指无可奈何，无法可想。"}
{"global_seq": 11207, "batch_seq": 7, "idiom_id": "idiom-11207", "text": "不宁唯是", "pinyin": "bù níng wéi shì", "short_explanation": "宁：语助词，无义。"}
{"global_seq": 11208, "batch_seq": 8, "idiom_id": "idiom-11208", "text": "不宾之士", "pinyin": "bù bīn zhī shì", "short_explanation": "宾：客人。"}
{"global_seq": 11209, "batch_seq": 9, "idiom_id": "idiom-11209", "text": "不寒而栗", "pinyin": "bù hán ér lì", "short_explanation": "栗：畏惧，发抖。"}
{"global_seq": 11210, "batch_seq": 10, "idiom_id": "idiom-11210", "text": "不屈不挠", "pinyin": "bù qū bù náo", "short_explanation": "屈：屈服。"}
{"global_seq": 11211, "batch_seq": 11, "idiom_id": "idiom-11211", "text": "不屑一顾", "pinyin": "bù xiè yī gù", "short_explanation": "不屑：不值得，不愿意。"}
{"global_seq": 11212, "batch_seq": 12, "idiom_id": "idiom-11212", "text": "不屑置辩", "pinyin": "bù xiè zhì biàn", "short_explanation": "屑：认为值得。"}
{"global_seq": 11213, "batch_seq": 13, "idiom_id": "idiom-11213", "text": "不差毫发", "pinyin": "bù chā háo fà", "short_explanation": "毫、发：都是古代的长度名，十毫为发，十发为。"}
{"global_seq": 11214, "batch_seq": 14, "idiom_id": "idiom-11214", "text": "不幸之幸", "pinyin": "bù xìng zhī xìng", "short_explanation": "包含在灾祸或不幸之中可使人宽慰、庆幸的成分。"}
{"global_seq": 11215, "batch_seq": 15, "idiom_id": "idiom-11215", "text": "不废江河", "pinyin": "bù fèi jiāng hé", "short_explanation": "赞扬作家或其著作流传不朽。"}
{"global_seq": 11216, "batch_seq": 16, "idiom_id": "idiom-11216", "text": "不徐不疾", "pinyin": "bù xú bù jí", "short_explanation": "徐：慢。"}
{"global_seq": 11217, "batch_seq": 17, "idiom_id": "idiom-11217", "text": "不得不尔", "pinyin": "bù dé bù ěr", "short_explanation": "尔：如此。"}
{"global_seq": 11218, "batch_seq": 18, "idiom_id": "idiom-11218", "text": "不得善终", "pinyin": "bù dé shàn zhōng", "short_explanation": "善终：正常死亡。"}
{"global_seq": 11219, "batch_seq": 19, "idiom_id": "idiom-11219", "text": "不得违误", "pinyin": "bù dé wéi wù", "short_explanation": "公文用语，不得违反命令，耽误公事。"}
{"global_seq": 11220, "batch_seq": 20, "idiom_id": "idiom-11220", "text": "不德而功", "pinyin": "bù dé ér gōng", "short_explanation": "不：无。"}
{"global_seq": 11221, "batch_seq": 21, "idiom_id": "idiom-11221", "text": "不忍释手", "pinyin": "bù rěn shì shǒu", "short_explanation": "舍不得放手。"}
{"global_seq": 11222, "batch_seq": 22, "idiom_id": "idiom-11222", "text": "不忘久要", "pinyin": "bù wàng jiǔ yào", "short_explanation": "久要：旧约，旧交。"}
